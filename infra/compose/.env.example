# Porkpie Sync Server
# Replace all placeholder values before real use.

PORKPIE_PUBLIC_URL=https://sync.porkpie.love
PORKPIE_SERVER_BIND=0.0.0.0:8080
PORKPIE_DATABASE_URL=sqlite:///data/porkpie-server.db

# Generate a real secret before using in production:
#   openssl rand -hex 32
#   [Convert]::ToHexString([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32)).ToLower()
# The server will reject this placeholder at runtime.
PORKPIE_API_KEY=generate-a-64-character-random-secret
